{
  "format_version": "1.21.70",
  "minecraft:entity": {
    "description": {
      "identifier": "eoa:warthog",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true,
      "properties": {}
    },
    "component_groups": {
      "eoa:warthog_baby": {
        "minecraft:is_baby": {},
        "minecraft:scale": {
          "value": 0.26
        },
        "minecraft:ageable": {
          "duration": 120000,
          "feed_items": [
            {
              "item": "beetroot",
              "growth": 0.01
            },
            {
              "item": "apple",
              "growth": 0.01
            }
          ],
          "grow_up": {
            "event": "minecraft:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 5,
          "speed_multiplier": 1.1
        }
      },

      "eoa:warthog_adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/warthog.json"
        },
        "minecraft:behavior.breed": {
          "priority": 6,
          "speed_multiplier": 1.0
        },
        "minecraft:breedable": {
          "require_tame": false,
          "breeds_with": {
            "mate_type": "eoa:sow",
            "baby_type": "eoa:sow",
            "breed_event": {
              "event": "minecraft:entity_born",
              "target": "baby"
            }
          },
          "breed_items": ["beetroot", "apple"],
          "property_inheritance": {
            "minecraft:climate_variant": {}
          }
        }
      }
    },

    "components": {
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:type_family": {
        "family": ["pig", "mob"]
      },
      "minecraft:scale": {
        "value": 0.70
      },

      "minecraft:behavior.float": {
        "priority": 1
      },
      "minecraft:behavior.panic": {
        "priority": 2,
        "speed_multiplier": 5.0
      },
      "minecraft:behavior.tempt": {
        "priority": 3,
        "speed_multiplier": 1.2,
        "items": ["beetroot", "apple"],
        "can_tempt_while_ridden": false
      },
      "minecraft:behavior.nearest_attackable_target": {
        "priority": 4,
        "must_see": true,
        "reselect_targets": true,
        "within_radius": 12.0,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "player"
            },
            "max_dist": 12
          }
        ]
      },
      "minecraft:behavior.melee_attack": {
        "priority": 5
      },
      "minecraft:behavior.breed": {
        "priority": 6,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.random_stroll": {
        "priority": 7,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.look_at_player": {
        "priority": 8,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9
      },

      "minecraft:attack": {
        "damage": 2
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:nameable": {},
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:collision_box": {
        "width": 0.9,
        "height": 0.9
      },
      "minecraft:leashable": {
        "soft_distance": 4.0,
        "hard_distance": 6.0,
        "max_distance": 10.0
      },
      "minecraft:balloonable": {
        "mass": 0.9
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:physics": {},
      "minecraft:pushable": {
        "is_pushable": true,
        "is_pushable_by_piston": true
      },
      "minecraft:conditional_bandwidth_optimization": {}
    },

    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "randomize": [
              {
                "weight": 95,
                "trigger": "minecraft:spawn_adult"
              },
              {
                "weight": 5,
                "add": {
                  "component_groups": [
                    "eoa:warthog_baby"
                  ]
                }
              }
            ]
          }
        ]
      },
      "minecraft:entity_born": {
        "remove": {},
        "add": {
          "component_groups": [
            "eoa:warthog_baby"
          ]
        }
      },
      "minecraft:ageable_grow_up": {
        "remove": {
          "component_groups": [
            "eoa:warthog_baby"
          ]
        },
        "add": {
          "component_groups": [
            "eoa:warthog_adult"
          ]
        }
      },
      "minecraft:spawn_adult": {
        "add": {
          "component_groups": [
            "eoa:warthog_adult"
          ]
        }
      }
    }
  }
}