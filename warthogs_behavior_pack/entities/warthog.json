{
  "format_version": "1.26.10",
  "minecraft:entity": {
    "description": {
      "identifier": "eoa:warthog",
      "spawn_category": "creature",
      "is_spawnable": true,
      "is_summonable": true
    },

    "component_groups": {
      "eoa:warthog_baby": {
        "minecraft:is_baby": {},
        "minecraft:scale": {
          "value": 0.35
        },
        "minecraft:ageable": {
          "duration": 120000,
          "feed_items": ["beetroot", "apple"],
          "pause_growth_items": ["golden_dandelion"],
          "reset_growth_items": ["golden_dandelion"],
          "grow_up": {
            "event": "minecraft:ageable_grow_up",
            "target": "self"
          }
        },
        "minecraft:behavior.follow_parent": {
          "priority": 5,
          "speed_multiplier": 1.1
        },
        "minecraft:on_target_acquired": {
          "event": "eoa:on_scared",
          "target": "self"
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 4,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "player"
              },
              "max_dist": 16
            }
          ]
        }
      },

      "eoa:warthog_baby_scared": {
        "minecraft:angry": {
          "duration": 1,
          "broadcast_anger": true,
          "broadcast_range": 41,
          "calm_event": {
            "event": "eoa:baby_on_calm",
            "target": "self"
          }
        }
      },

      "eoa:warthog_adult": {
        "minecraft:experience_reward": {
          "on_bred": "Math.Random(1,7)",
          "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
        },
        "minecraft:loot": {
          "table": "loot_tables/entities/warthog.json"
        },
        "minecraft:spawn_entity": {
          "entities": [
            {
              "min_wait_time": 150,
              "max_wait_time": 300,
              "spawn_sound": "plop",
              "spawn_item": "eoa:manure",
              "filters": {
                "test": "rider_count",
                "subject": "self",
                "operator": "==",
                "value": 0
              }
            }
          ]
        },        
        "minecraft:behavior.breed": {
          "priority": 6,
          "speed_multiplier": 1.0
        },
        "minecraft:breedable": {
          "require_tame": false,
          "breeds_with": {
            "eoa:warthog": {}
          },
          "breed_items": ["beetroot", "apple"]
        }
      },

      "eoa:warthog_adult_wild": {
        "minecraft:on_target_acquired": {
          "event": "eoa:on_anger",
          "target": "self"
        },
        "minecraft:on_friendly_anger": {
          "event": "eoa:on_anger",
          "target": "self"
        }
      },

      "eoa:warthog_adult_hostile": {
        "minecraft:attack": {
          "damage": 3
        },
        "minecraft:angry": {
          "duration": 500,
          "broadcast_anger": false,
          "broadcast_range": 20,
          "calm_event": {
            "event": "eoa:on_calm",
            "target": "self"
          }
        },
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 4,
          "must_see": true,
          "reselect_targets": true,
          "within_radius": 16.0,
          "entity_types": [
            {
              "filters": {
                "test": "is_family",
                "subject": "other",
                "value": "player"
              },
              "max_dist": 16
            }
          ]
        },
        "minecraft:behavior.melee_attack": {
          "priority": 5
        }
      }
    },

    "components": {
      "minecraft:offspring": {
        "offspring_pairs": {
          "eoa:warthog": "eoa:warthog"
        }
      },
      "minecraft:is_hidden_when_invisible": {},
      "minecraft:type_family": {
        "family": ["pig", "mob"]
      },
      "minecraft:scale": {
        "value": 0.60
      },
      "minecraft:breathable": {
        "total_supply": 15,
        "suffocate_time": 0
      },
      "minecraft:nameable": {},
      "minecraft:health": {
        "value": 20,
        "max": 20
      },
      "minecraft:hurt_on_condition": {
        "damage_conditions": [
          {
            "filters": {
              "test": "in_lava",
              "subject": "self",
              "operator": "==",
              "value": true
            },
            "cause": "lava",
            "damage_per_tick": 4
          }
        ]
      },
      "minecraft:movement": {
        "value": 0.25
      },
      "minecraft:navigation.walk": {
        "can_path_over_water": true,
        "avoid_water": true,
        "avoid_damage_blocks": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:can_climb": {},
      "minecraft:collision_box": {
        "width": 0.9,
        "height": 0.9
      },
      "minecraft:leashable": {
        "soft_distance": 4.0,
        "hard_distance": 6.0,
        "max_distance": 10.0
      },
      "minecraft:balloonable": {
        "mass": 0.9
      },
      "minecraft:despawn": {
        "despawn_from_distance": {}
      },
      "minecraft:physics": {},
      "minecraft:pushable_by_entity": {},
      "minecraft:pushable_by_block": {},
      "minecraft:conditional_bandwidth_optimization": {},

      "minecraft:behavior.float": {
        "priority": 1
      },
      "minecraft:behavior.panic": {
        "priority": 2,
        "speed_multiplier": 6.0
      },
      "minecraft:behavior.tempt": {
        "priority": 3,
        "speed_multiplier": 1.2,
        "items": ["beetroot", "apple"],
        "can_tempt_while_ridden": false
      },
      "minecraft:behavior.avoid_mob_type": {
        "priority": 4,
        "entity_types": [
          {
            "filters": {
              "test": "is_family",
              "subject": "other",
              "value": "player"
            },
            "max_dist": 64,
            "walk_speed_multiplier": 1.0,
            "sprint_speed_multiplier": 3.0
          }
        ]
      },
      "minecraft:behavior.random_stroll": {
        "priority": 7,
        "speed_multiplier": 1.0
      },
      "minecraft:behavior.look_at_player": {
        "priority": 8,
        "look_distance": 6.0,
        "probability": 0.02
      },
      "minecraft:behavior.random_look_around": {
        "priority": 9
      }
    },

    "events": {
      "minecraft:entity_spawned": {
        "sequence": [
          {
            "randomize": [
              {
                "weight": 67,
                "add": {
                  "component_groups": [
                    "eoa:warthog_adult",
                    "eoa:warthog_adult_wild"
                  ]
                }
              },
              {
                "weight": 33,
                "add": {
                  "component_groups": [
                    "eoa:warthog_baby"
                  ]
                }
              }
            ]
          }
        ]
      },
      "minecraft:entity_born": {
        "remove": {},
        "add": {
          "component_groups": [
            "eoa:warthog_baby"
          ]
        }
      },
      "minecraft:ageable_grow_up": {
        "remove": {
          "component_groups": [
            "eoa:warthog_baby",
            "eoa:warthog_baby_scared"
          ]
        },
        "add": {
          "component_groups": [
            "eoa:warthog_adult",
            "eoa:warthog_adult_wild"
          ]
        }
      },
      "eoa:on_anger": {
        "remove": {
          "component_groups": [
            "eoa:warthog_adult_wild"
          ]
        },
        "add": {
          "component_groups": [
            "eoa:warthog_adult_hostile"
          ]
        }
      },
      "eoa:on_calm": {
        "remove": {
          "component_groups": [
            "eoa:warthog_adult_hostile"
          ]
        },
        "add": {
          "component_groups": [
            "eoa:warthog_adult_wild"
          ]
        }
      },
      "eoa:on_scared": {
        "remove": {
          "component_groups": [
            "eoa:warthog_baby"
          ]
        },
        "add": {
          "component_groups": [
            "eoa:warthog_baby_scared"
          ]
        }
      },
      "eoa:baby_on_calm": {
        "remove": {
          "component_groups": [
            "eoa:warthog_baby_scared"
          ]
        },
        "add": {
          "component_groups": [
            "eoa:warthog_baby"
          ]
        }
      }
    }
  }
}